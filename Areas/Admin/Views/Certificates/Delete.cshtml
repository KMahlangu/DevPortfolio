@model DevPortfolio.Models.Certificate

@{
    ViewData["Title"] = "Delete Certificate";
    Layout = "_AdminLayout";
}

<div class="container">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card shadow border-danger">
                <div class="card-header bg-danger text-white">
                    <h2><i class="bi bi-exclamation-triangle"></i> Delete Certificate</h2>
                </div>
                <div class="card-body">
                    <div class="alert alert-warning">
                        <h4 class="alert-heading">Are you sure?</h4>
                        <p>You are about to delete the certificate: <strong>@Model.Title</strong></p>
                        <p>This action cannot be undone.</p>
                    </div>

                    <div class="card mb-3">
                        <div class="card-body">
                            <dl class="row">
                                <dt class="col-sm-4">Title</dt>
                                <dd class="col-sm-8">@Model.Title</dd>

                                <dt class="col-sm-4">Organization</dt>
                                <dd class="col-sm-8">@Model.IssuingOrganization</dd>

                                <dt class="col-sm-4">Issue Date</dt>
                                <dd class="col-sm-8">@Model.IssueDate.ToString("MMMM yyyy")</dd>

                                @if (!string.IsNullOrEmpty(Model.CertificateFileUrl))
                                {
                                    <dt class="col-sm-4">PDF File</dt>
                                    <dd class="col-sm-8">
                                        <a href="@Model.CertificateFileUrl" target="_blank">View PDF</a>
                                    </dd>
                                }
                            </dl>
                        </div>
                    </div>

                    <form asp-area="Admin" asp-controller="Certificates" asp-action="Delete" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Id" />
                        <button type="submit" class="btn btn-danger">
                            <i class="bi bi-trash"></i> Confirm Delete
                        </button>
                        <a asp-area="Admin" asp-controller="Certificates" asp-action="Index"
                           class="btn btn-secondary">
                            <i class="bi bi-x-circle"></i> Cancel
                        </a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>