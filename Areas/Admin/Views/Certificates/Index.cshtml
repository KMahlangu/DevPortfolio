@model IEnumerable<DevPortfolio.Models.Certificate>

@{
    ViewData["Title"] = "Manage Certificates";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-patch-check"></i> Manage Certificates</h1>
    <a asp-area="Admin" asp-controller="Certificates" asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Add New Certificate
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card">
    <div class="card-body">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Certificate</th>
                    <th>Issuing Organization</th>
                    <th>Issue Date</th>
                    <th>Expiration</th>
                    <th>PDF</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var cert in Model)
                {
                    <tr>
                        <td>@cert.Id</td>
                        <td><strong>@cert.Title</strong></td>
                        <td>@cert.IssuingOrganization</td>
                        <td>@cert.IssueDate.ToString("MMM yyyy")</td>
                        <td>
                            @if (cert.ExpirationDate.HasValue)
                            {
                                @cert.ExpirationDate.Value.ToString("MMM yyyy")
                            }
                            else
                            {
                                <span class="text-muted">No expiration</span>
                            }
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(cert.CertificateFileUrl))
                            {
                                <a href="@cert.CertificateFileUrl" target="_blank" class="btn btn-sm btn-success">
                                    <i class="bi bi-file-pdf"></i> View
                                </a>
                            }
                            else
                            {
                                <span class="badge bg-secondary">No PDF</span>
                            }
                        </td>
                        <td>
                            <div class="btn-group" role="group">
                                <a asp-area="Admin" asp-controller="Certificates" asp-action="Details"
                                   asp-route-id="@cert.Id" class="btn btn-sm btn-info" title="Details">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-area="Admin" asp-controller="Certificates" asp-action="Edit"
                                   asp-route-id="@cert.Id" class="btn btn-sm btn-warning" title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-area="Admin" asp-controller="Certificates" asp-action="Delete"
                                   asp-route-id="@cert.Id" class="btn btn-sm btn-danger" title="Delete"
                                   onclick="return confirm('Are you sure you want to delete @cert.Title?');">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @if (!Model.Any())
        {
            <div class="text-center py-4">
                <p class="text-muted">No certificates found. Click "Add New Certificate" to create one.</p>
            </div>
        }
    </div>
</div>