@model DevPortfolio.Models.Certificate

@{
    ViewData["Title"] = $"Certificate Details - {Model.Title}";
    Layout = "_AdminLayout";
}

<div class="container-fluid">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1><i class="bi bi-patch-check text-primary"></i> Certificate Details</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
                    <li class="breadcrumb-item"><a asp-area="Admin" asp-controller="Certificates" asp-action="Index">Certificates</a></li>
                    <li class="breadcrumb-item active">@Model.Title</li>
                </ol>
            </nav>
        </div>
        <div>
            <a asp-area="Admin" asp-controller="Certificates" asp-action="Edit" asp-route-id="@Model.Id"
               class="btn btn-warning me-2">
                <i class="bi bi-pencil"></i> Edit
            </a>
            <a asp-area="Admin" asp-controller="Certificates" asp-action="Index"
               class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Back
            </a>
        </div>
    </div>

    <!-- Details Card -->
    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0"><i class="bi bi-info-circle"></i> Certificate Information</h4>
                </div>
                <div class="card-body">
                    <table class="table table-bordered">
                        <tr>
                            <th style="width: 200px;">ID</th>
                            <td><strong>@Model.Id</strong></td>
                        </tr>
                        <tr>
                            <th>Title</th>
                            <td><h4>@Model.Title</h4></td>
                        </tr>
                        <tr>
                            <th>Issuing Organization</th>
                            <td>@Model.IssuingOrganization</td>
                        </tr>
                        <tr>
                            <th>Issue Date</th>
                            <td>@Model.IssueDate.ToString("MMMM dd, yyyy")</td>
                        </tr>
                        @if (Model.ExpirationDate.HasValue)
                        {
                            <tr>
                                <th>Expiration Date</th>
                                <td>@Model.ExpirationDate.Value.ToString("MMMM dd, yyyy")</td>
                            </tr>
                        }
                        <tr>
                            <th>Credential ID</th>
                            <td>@(Model.CredentialId ?? "Not provided")</td>
                        </tr>
                        <tr>
                            <th>Credential URL</th>
                            <td>
                                @if (!string.IsNullOrEmpty(Model.CredentialUrl))
                                {
                                    <a href="@Model.CredentialUrl" target="_blank">@Model.CredentialUrl</a>
                                }
                                else
                                {
                                    <span class="text-muted">Not provided</span>
                                }
                            </td>
                        </tr>
                        <tr>
                            <th>Skills Gained</th>
                            <td>
                                @if (!string.IsNullOrEmpty(Model.SkillsGained))
                                {
                                    var skills = Model.SkillsGained.Split(new[] { ',', ';' }, StringSplitOptions.RemoveEmptyEntries);
                                    foreach (var skill in skills)
                                    {
                                        <span class="badge bg-info me-1 p-2">@skill.Trim()</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">No skills specified</span>
                                }
                            </td>
                        </tr>
                        <tr>
                            <th>Certificate File</th>
                            <td>
                                @if (!string.IsNullOrEmpty(Model.CertificateFileUrl))
                                {
                                    <a href="@Model.CertificateFileUrl" target="_blank" class="btn btn-success">
                                        <i class="bi bi-file-pdf"></i> View PDF Certificate
                                    </a>
                                    <a asp-area="Admin" asp-controller="Certificates" asp-action="Download"
                                       asp-route-id="@Model.Id" class="btn btn-primary ms-2">
                                        <i class="bi bi-download"></i> Download
                                    </a>
                                }
                                else
                                {
                                    <span class="text-muted">No PDF uploaded</span>
                                }
                            </td>
                        </tr>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>