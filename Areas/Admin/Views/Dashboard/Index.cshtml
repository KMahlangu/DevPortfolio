@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "_AdminLayout";

}

<div class="container-fluid">
    <h1>Welcome to Admin Dashboard</h1>
    <p>You're logged in as @User.Identity.Name</p>

    <div class="row mt-4">
        <div class="col-md-3 mb-3">
            <div class="card bg-primary text-white">
                <div class="card-body">
                    <h5 class="card-title">Skills</h5>
                    <p class="card-text display-6">0</p>
                    <a asp-controller="Skills" asp-action="index" class="text-white">Manage →</a>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card bg-success text-white">
                <div class="card-body">
                    <h5 class="card-title">Projects</h5>
                    <p class="card-text diplay-6">0</p>
                    <a asp-controller="Projects" asp-cation="index" class="text-white">Manage →</a>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card bg-info text-white">
                <div class="card-body">
                    <h5 class="card-title">Services</h5>
                    <p class="card-text display-6">0</p>
                    <a asp-controller="Services" asp-action="index" class="text-white">Manage →</a>
                </div>
            </div>
        </div>
    </div>
</div>