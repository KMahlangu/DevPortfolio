@model DevPortfolio.Models.Skill

@{
    ViewData["Title"] = "Delete Skill";
    Layout = "_AdminLayout";
}

<h1>Delete Skill</h1>

<div class="alert alert-danger">
    <h3>Are you sure you want to delete this skill?</h3>
</div>

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-2">Name</dt>
            <dd class="col-sm-10">@Model.Name</dd>
            
            <dt class="col-sm-2">Category</dt>
            <dd class="col-sm-10">@Model.Category</dd>
            
            <dt class="col-sm-2">Level</dt>
            <dd class="col-sm-10">@Model.Level%</dd>
        </dl>
        
        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <input type="submit" value="Delete" class="btn btn-danger" />
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>