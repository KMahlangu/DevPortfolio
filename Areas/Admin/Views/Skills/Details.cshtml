@model DevPortfolio.Models.Skill

@{
    ViewData["Title"] = $"Skill Details - {Model.Name}";
    Layout = "_AdminLayout";
}

<div class="container-fluid">
    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1><i class="bi bi-tools"></i> Skill Details</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
                    <li class="breadcrumb-item"><a asp-area="Admin" asp-controller="Skills" asp-action="Index">Skills</a></li>
                    <li class="breadcrumb-item active">@Model.Name</li>
                </ol>
            </nav>
        </div>
        <div>
            <a asp-area="Admin" asp-controller="Skills" asp-action="Edit" asp-route-id="@Model.Id"
               class="btn btn-warning">
                <i class="bi bi-pencil"></i> Edit
            </a>
            <a asp-area="Admin" asp-controller="Skills" asp-action="Index"
               class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Back to List
            </a>
        </div>
    </div>

    <!-- Details Card -->
    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0"><i class="bi bi-info-circle"></i> Skill Information</h4>
                </div>
                <div class="card-body">
                    <table class="table table-bordered table-striped">
                        <tr>
                            <th style="width: 200px;">ID</th>
                            <td><strong>@Model.Id</strong></td>
                        </tr>
                        <tr>
                            <th>Name</th>
                            <td>@Model.Name</td>
                        </tr>
                        <tr>
                            <th>Category</th>
                            <td>
                                <span class="badge bg-info">@Model.Category</span>
                            </td>
                        </tr>
                        <tr>
                            <th>Proficiency Level</th>
                            <td>
                                <div class="d-flex align-items-center">
                                    <span class="me-3">@Model.Level%</span>
                                    <div class="progress flex-grow-1" style="height: 20px;">
                                        <div class="progress-bar" style="width: @Model.Level%">
                                            @Model.Level%
                                        </div>
                                    </div>
                                </div>
                            </td>
                        </tr>
                        <tr>
                            <th>Created/Added</th>
                            <td>@DateTime.Now.ToString("MMMM dd, yyyy")</td>
                        </tr>
                    </table>
                </div>
                <div class="card-footer">
                    <small class="text-muted">Last updated: @DateTime.Now.ToString("g")</small>
                </div>
            </div>
        </div>
    </div>
</div>