@model IEnumerable<DevPortfolio.Models.Skill>

@{
    ViewData["Title"] = "Manage Skills";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-tools"></i> Manage Skills</h1>
    <a asp-area="Admin" asp-controller="Skills" asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Add New Skill
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card">
    <div class="card-body">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Category</th>
                    <th>Level</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var skill in Model)
                {
                    <tr>
                        <td>@skill.Id</td>
                        <td><strong>@skill.Name</strong></td>
                        <td><span class="badge bg-info">@skill.Category</span></td>
                        <td style="width: 200px;">
                            <div class="progress">
                                <div class="progress-bar" style="width: @skill.Level%">
                                    @skill.Level%
                                </div>
                            </div>
                        </td>
                        <td>
                            <div class="btn-group" role="group">
                                <a asp-area="Admin" asp-controller="Skills" asp-action="Edit" 
                                   asp-route-id="@skill.Id" class="btn btn-sm btn-warning" 
                                   title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-area="Admin" asp-controller="Skills" asp-action="Details" 
                                   asp-route-id="@skill.Id" class="btn btn-sm btn-info" 
                                   title="Details">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-area="Admin" asp-controller="Skills" asp-action="Delete" 
                                   asp-route-id="@skill.Id" class="btn btn-sm btn-danger" 
                                   title="Delete"
                                   onclick="return confirm('Are you sure you want to delete @skill.Name?');">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        
        @if (!Model.Any())
        {
            <div class="text-center py-4">
                <p class="text-muted">No skills found. Click "Add New Skill" to create one.</p>
            </div>
        }
    </div>
</div>

