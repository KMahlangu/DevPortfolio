@model DevPortfolio.Models.Skill

@{
    ViewData["Title"] = "Edit Skill";
    Layout = "_AdminLayout";
}

<h1>Edit Skill</h1>

<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <!-- IMPORTANT: The ID is passed in the route, not as a hidden field -->
                <form asp-area="Admin" asp-controller="Skills" asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()

                    <!-- CRITICAL: This hidden field ensures the ID is sent back -->
                    <input type="hidden" asp-for="Id" />
                    
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label"></label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                    
                    <div class="mb-3">
                        <label asp-for="Category" class="form-label"></label>
                        <input asp-for="Category" class="form-control" />
                        <span asp-validation-for="Category" class="text-danger"></span>
                    </div>
                    
                    <div class="mb-3">
                        <label asp-for="Level" class="form-label"></label>
                        <input asp-for="Level" class="form-control" type="number" />
                        <span asp-validation-for="Level" class="text-danger"></span>
                    </div>
                    
                    <div class="form-group my-4">
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-save"></i> Update Skill
                        </button>
                        <a href="@Url.Action("Index", "Skills", new { area = "Admin" })" class="btn btn-secondary">
                            <i class="bi bi-x-circle"></i> Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}