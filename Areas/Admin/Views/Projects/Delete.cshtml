@model DevPortfolio.Models.Project

@{
    ViewData["Title"] = "Delete Project";
    Layout = "_AdminLayout";
}

<h1>Delete Project</h1>

<div class="alert alert-danger">
    <h3>Are you sure you want to delete this skill?</h3>
</div>

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-2">Title</dt>
            <dd class="col-sm-10">@Model.Title</dd>

            <dt class="col-sm-2">Description</dt>
            <dd class="col-sm-10">@Model.Description</dd>

            <dt class="col-sm-2">Technologies</dt>
            <dd class="col-sm-10">@Model.Technologies</dd>

            <dt class="col-sm-2">G</dt>GitHubUrl
            <dd class="col-sm-10">@Model.GitHubUrl</dd>

            <dt class="col-sm-2">liveUrl</dt>
            <dd class="col-sm-10">@Model.LiveUrl</dd>
        </dl>

        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <input type="submit" value="Delete" class="btn btn-danger" />
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>