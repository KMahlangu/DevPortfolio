@model IEnumerable<DevPortfolio.Models.ContactMessage>

@{
    ViewData["Title"] = "Contact Messages";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1><i class="bi bi-envelope"></i> Contact Messages</h1>
        <p class="text-muted">Manage messages received from the contact form</p>
    </div>
    <div>
        <a asp-action="Export" class="btn btn-success me-2">
            <i class="bi bi-download"></i> Export to CSV
        </a>
        <button type="button" class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#deleteAllModal">
            <i class="bi bi-trash"></i> Delete All
        </button>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Statistics Cards -->
<div class="row mb-4">
    <div class="col-md-3">
        <div class="card text-white bg-primary">
            <div class="card-body">
                <h5 class="card-title">Total Messages</h5>
                <h2 class="mb-0">@Model.Count()</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-success">
            <div class="card-body">
                <h5 class="card-title">Read</h5>
                <h2 class="mb-0">@Model.Count(m => m.IsRead)</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-warning">
            <div class="card-body">
                <h5 class="card-title">Unread</h5>
                <h2 class="mb-0">@Model.Count(m => !m.IsRead)</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-info">
            <div class="card-body">
                <h5 class="card-title">Last 7 Days</h5>
                <h2 class="mb-0">@Model.Count(m => m.DateSent >= DateTime.Now.AddDays(-7))</h2>
            </div>
        </div>
    </div>
</div>

<!-- Messages Table -->
<div class="card">
    <div class="card-body">
        <table class="table table-striped table-hover" id="messagesTable">
            <thead class="table-dark">
                <tr>
                    <th>Status</th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Subject</th>
                    <th>Date Sent</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var message in Model)
                {
                    <tr class="@(message.IsRead ? "" : "table-primary fw-bold")">
                        <td>
                            @if (message.IsRead)
                            {
                                <span class="badge bg-secondary" title="Read on @(message.DateRead?.ToString("MMM dd, yyyy HH:mm"))">
                                    <i class="bi bi-check-circle"></i> Read
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-success">
                                    <i class="bi bi-envelope-fill"></i> New
                                </span>
                            }
                        </td>
                        <td>@message.Name</td>
                        <td>
                            <a href="mailto:@message.Email">@message.Email</a>
                        </td>
                        <td>@message.Subject</td>
                        <td>
                            @message.DateSent.ToString("MMM dd, yyyy HH:mm")
                            <br />
                            <small class="text-muted">@message.DateSent.ToString("ddd")</small>
                        </td>
                        <td>
                            <div class="btn-group" role="group">
                                <a asp-action="Details" asp-route-id="@message.Id"
                                   class="btn btn-sm btn-info" title="View Details">
                                    <i class="bi bi-eye"></i>
                                </a>

                                @if (!message.IsRead)
                                {
                                    <form asp-action="MarkAsRead" asp-route-id="@message.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-success" title="Mark as Read">
                                            <i class="bi bi-check2-circle"></i>
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <form asp-action="MarkAsUnread" asp-route-id="@message.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-warning" title="Mark as Unread">
                                            <i class="bi bi-envelope"></i>
                                        </button>
                                    </form>
                                }

                                <a asp-action="Delete" asp-route-id="@message.Id"
                                   class="btn btn-sm btn-danger" title="Delete">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-envelope-open display-1 text-muted"></i>
                <h3 class="mt-3 text-muted">No messages yet</h3>
                <p>When visitors send messages through the contact form, they'll appear here.</p>
            </div>
        }
    </div>
</div>

<!-- Delete All Confirmation Modal -->
<div class="modal fade" id="deleteAllModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">
                    <i class="bi bi-exclamation-triangle"></i> Delete All Messages
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete <strong>ALL</strong> messages?</p>
                <p class="text-danger">This action cannot be undone!</p>
            </div>
            <div class="modal-footer">
                <form asp-action="DeleteAll" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash"></i> Yes, Delete All
                    </button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        <i class="bi bi-x-circle"></i> Cancel
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Add search/filter functionality
        $(document).ready(function() {
            $("#searchInput").on("keyup", function() {
                var value = $(this).val().toLowerCase();
                $("#messagesTable tbody tr").filter(function() {
                    $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1)
                });
            });
        });
    </script>
}