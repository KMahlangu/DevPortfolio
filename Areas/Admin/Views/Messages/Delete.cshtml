@model DevPortfolio.Models.ContactMessage

@{
    ViewData["Title"] = "Delete Message";
    Layout = "_AdminLayout";
}

<div class="container">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card shadow border-danger">
                <div class="card-header bg-danger text-white">
                    <h2><i class="bi bi-exclamation-triangle"></i> Delete Message</h2>
                </div>
                <div class="card-body">
                    <div class="alert alert-warning">
                        <h4 class="alert-heading">Are you sure?</h4>
                        <p>You are about to delete a message from <strong>@Model.Name</strong>.</p>
                        <p>This action cannot be undone.</p>
                    </div>

                    <div class="card mb-3">
                        <div class="card-header">
                            <h5>Message Summary</h5>
                        </div>
                        <div class="card-body">
                            <dl class="row">
                                <dt class="col-sm-3">From:</dt>
                                <dd class="col-sm-9">@Model.Name (@Model.Email)</dd>

                                <dt class="col-sm-3">Subject:</dt>
                                <dd class="col-sm-9">@Model.Subject</dd>

                                <dt class="col-sm-3">Date:</dt>
                                <dd class="col-sm-9">@Model.DateSent.ToString("MMM dd, yyyy HH:mm")</dd>

                                <dt class="col-sm-3">Status:</dt>
                                <dd class="col-sm-9">
                                    @if (Model.IsRead)
                                    {
                                        <span class="badge bg-secondary">Read</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">Unread</span>
                                    }
                                </dd>
                            </dl>

                            <div class="mt-3">
                                <strong>Message Preview:</strong>
                                <div class="bg-light p-3 rounded mt-2">
                                    <p class="mb-0">@(Model.Message.Length > 100 ? Model.Message.Substring(0, 100) + "..." : Model.Message)</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <form asp-action="Delete" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Id" />
                        <button type="submit" class="btn btn-danger">
                            <i class="bi bi-trash"></i> Confirm Delete
                        </button>
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-x-circle"></i> Cancel
                        </a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>