@model DevPortfolio.Models.ContactMessage

@{
    ViewData["Title"] = "Message Details";
    Layout = "_AdminLayout";
}

<div class="container-fluid">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1><i class="bi bi-envelope"></i> Message Details</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
                    <li class="breadcrumb-item"><a asp-area="Admin" asp-controller="Messages" asp-action="Index">Messages</a></li>
                    <li class="breadcrumb-item active">From @Model.Name</li>
                </ol>
            </nav>
        </div>
        <div>
            <a asp-area="Admin" asp-controller="Messages" asp-action="Index" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Back to List
            </a>
        </div>
    </div>

    <!-- Message Details Card -->
    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card shadow">
                <div class="card-header @(Model.IsRead ? "bg-secondary" : "bg-primary") text-white">
                    <div class="d-flex justify-content-between align-items-center">
                        <h4 class="mb-0">
                            <i class="bi bi-info-circle"></i> Message Information
                        </h4>
                        <span class="badge @(Model.IsRead ? "bg-light text-dark" : "bg-success")">
                            @(Model.IsRead ? "Read" : "New")
                        </span>
                    </div>
                </div>
                <div class="card-body">
                    <table class="table table-bordered">
                        <tr>
                            <th style="width: 150px;">From</th>
                            <td>
                                <strong>@Model.Name</strong><br />
                                <a href="mailto:@Model.Email">@Model.Email</a>
                            </td>
                        </tr>
                        <tr>
                            <th>Subject</th>
                            <td><h5>@Model.Subject</h5></td>
                        </tr>
                        <tr>
                            <th>Date Sent</th>
                            <td>@Model.DateSent.ToString("dddd, MMMM dd, yyyy 'at' hh:mm tt")</td>
                        </tr>
                        @if (Model.DateRead.HasValue)
                        {
                            <tr>
                                <th>Date Read</th>
                                <td>@Model.DateRead.Value.ToString("dddd, MMMM dd, yyyy 'at' hh:mm tt")</td>
                            </tr>
                        }
                        <tr>
                            <th>IP Address</th>
                            <td>@(Model.IpAddress ?? "Not available")</td>
                        </tr>
                        <tr>
                            <th>User Agent</th>
                            <td><small class="text-muted">@(Model.UserAgent ?? "Not available")</small></td>
                        </tr>
                    </table>

                    <div class="mt-4">
                        <h5>Message:</h5>
                        <div class="card bg-light">
                            <div class="card-body">
                                <p class="pre-wrap" style="white-space: pre-wrap;">@Model.Message</p>
                            </div>
                        </div>
                    </div>

                    <div class="mt-4 d-flex gap-2">
                        <a href="mailto:@Model.Email?subject=Re: @Model.Subject" class="btn btn-primary">
                            <i class="bi bi-reply"></i> Reply via Email
                        </a>

                        @if (!Model.IsRead)
                        {
                            <form asp-action="MarkAsRead" asp-route-id="@Model.Id" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-success">
                                    <i class="bi bi-check2-circle"></i> Mark as Read
                                </button>
                            </form>
                        }
                        else
                        {
                            <form asp-action="MarkAsUnread" asp-route-id="@Model.Id" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-warning">
                                    <i class="bi bi-envelope"></i> Mark as Unread
                                </button>
                            </form>
                        }

                        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">
                            <i class="bi bi-trash"></i> Delete
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>