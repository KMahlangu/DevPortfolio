                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <div class="card-body text-center">
                    <i class="bi bi-database service-icon"></i>
                    <h3>Database</h3>
                    <p>Efficient data modeling and optimization</p>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <div class="card-body text-center">
                    <i class="bi bi-cloud service-icon"></i>
                    <h3>Cloud</h3>
                    <p>Deploying and scaling applications in the cloud</p>
                </div>
            </div>
        </div>
    </div>
