@{
    ViewData["Title"] = "Dashboard";
    Layout = "_Layout";

    // Safe way to get user name
    var userName = User.Identity?.Name ?? "Admin";
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-speedometer2"></i> Admin Dashboard</h1>
    @if (isAuthenticated)
    {
        <div>
            <span class="badge bg-success">Welcome, @userName</span>
        </div>
    }
</div>

<!-- Statistics Cards Row -->
<div class="row mb-4">
    <div class="col-md-3 mb-3">
        <div class="card text-white bg-primary h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="card-title">Skills</h6>
                        <h2 class="mb-0">@ViewBag.SkillsCount</h2>
                    </div>
                    <i class="bi bi-tools fs-1 opacity-50"></i>
                </div>
            </div>
            <div class="card-footer bg-transparent border-0">
                <a asp-area="Admin" asp-controller="Skills" asp-action="Index"
                   class="text-white text-decoration-none">
                    Manage Skills <i class="bi bi-arrow-right"></i>
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card text-white bg-success h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="card-title">Projects</h6>
                        <h2 class="mb-0">@ViewBag.ProjectsCount</h2>
                    </div>
                    <i class="bi bi-kanban fs-1 opacity-50"></i>
                </div>
            </div>
            <div class="card-footer bg-transparent border-0">
                <a asp-area="Admin" asp-controller="Projects" asp-action="Index"
                   class="text-white text-decoration-none">
                    Manage Projects <i class="bi bi-arrow-right"></i>
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card text-white bg-info h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="card-title">Services</h6>
                        <h2 class="mb-0">@ViewBag.ServicesCount</h2>
                    </div>
                    <i class="bi bi-gear fs-1 opacity-50"></i>
                </div>
            </div>
            <div class="card-footer bg-transparent border-0">
                <a asp-area="Admin" asp-controller="Services" asp-action="Index"
                   class="text-white text-decoration-none">
                    Manage Services <i class="bi bi-arrow-right"></i>
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card text-white bg-warning h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="card-title">Certificates</h6>
                        <h2 class="mb-0">@ViewBag.CertificatesCount</h2>
                    </div>
                    <i class="bi bi-patch-check fs-1 opacity-50"></i>
                </div>
            </div>
            <div class="card-footer bg-transparent border-0">
                <a asp-area="Admin" asp-controller="Certificates" asp-action="Index"
                   class="text-white text-decoration-none">
                    Manage Certificates <i class="bi bi-arrow-right"></i>
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Second Row for Messages -->
<div class="row mb-4">
    <div class="col-md-6 mb-3">
        <div class="card text-white bg-secondary h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="card-title">Messages</h6>
                        <h2 class="mb-0">@ViewBag.MessagesCount</h2>
                        @if (ViewBag.UnreadMessages > 0)
                        {
                            <span class="badge bg-danger">@ViewBag.UnreadMessages unread</span>
                        }
                    </div>
                    <i class="bi bi-envelope fs-1 opacity-50"></i>
                </div>
            </div>
            <div class="card-footer bg-transparent border-0">
                <a asp-area="Admin" asp-controller="Messages" asp-action="Index"
                   class="text-white text-decoration-none">
                    View Messages <i class="bi bi-arrow-right"></i>
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Recent Messages Section -->
@if (ViewBag.RecentMessages != null && ((IEnumerable<DevPortfolio.Models.ContactMessage>)ViewBag.RecentMessages).Any())
{
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0"><i class="bi bi-envelope"></i> Recent Messages</h5>
                </div>
                <div class="card-body">
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Subject</th>
                                <th>Date</th>
                                <th>Status</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var message in ViewBag.RecentMessages)
                            {
                                <tr>
                                    <td>@message.Name</td>
                                    <td>@message.Email</td>
                                    <td>@message.Subject</td>
                                    <td>@message.DateSent.ToString("MMM dd, yyyy")</td>
                                    <td>
                                        @if (message.IsRead)
                                        {
                                            <span class="badge bg-secondary">Read</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">New</span>
                                        }
                                    </td>
                                    <td>
                                        <a asp-area="Admin" asp-controller="Messages" asp-action="Details"
                                           asp-route-id="@message.Id" class="btn btn-sm btn-info">
                                            <i class="bi bi-eye"></i> View
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="row">
        <div class="col-12">
            <div class="alert alert-info">
                <i class="bi bi-info-circle"></i> No messages yet.
            </div>
        </div>
    </div>
}