@{
    ViewData["Title"] = "Home";
}

<!-- Hero Section -->
<section class="hero-section text-center">
    <div class="container">
        <h1 class="display-4">Hi, I'm Kutlwano Smauel Mahlangu</h1>
        <p class="lead">Software Engineer & ASP.NET Core Developer</p>
        <p>I create web applications that solve real-world problems and the solutions are wothwhile.</p>
        <a asp-controller="Portfolio" asp-action="Projects" class="btn btn-light btn-lg me-2">View My Work</a>
        <a asp-controller="Home" asp-action="Contact" class="btn btn-outline-light btn-lg">Get in Touch</a>
    </div>
</section>

<!-- Featured Sections -->
