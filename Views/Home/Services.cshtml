@model List<DevPortfolio.Models.Service>

@{
    ViewData["Title"] = "Services";
}

<h1 class="text-center mb-5">Services I Offer</h1>

<div class="row">
    @foreach (var service in Model.OrderBy(s => s.DisplayOrder))
    {
        <div class="col-md-6 col-lg-3 mb-4">
            <div class="card h-100 text-center shadow-sm hover-lift">
                <div class="card-body">
                    @if (!string.IsNullOrEmpty(service.IconClass))
                    {
                        <i class="bi @service.IconClass display-1 text-primary mb-3"></i>
                    }
                    <h5 class="card-title">@service.Title</h5>
                    <p class="card-text text-muted">@service.Description</p>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .hover-lift {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .hover-lift:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
    }
</style>